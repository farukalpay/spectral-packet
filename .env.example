# Spectral Packet Engine — Server Deployment
# Copy to .env and fill in real values.

SPE_SERVER_HOST=
SPE_SERVER_PORT=22
SPE_SERVER_USER=root
SPE_SERVER_PASSWORD=

SPE_DEPLOY_ROOT=/root/lightcap/spectral-packet-engine
SPE_VENV_PATH=/root/lightcap/spectral-packet-engine/.venv

SPE_MCP_TRANSPORT=stdio
SPE_MCP_LOG_FILE=/root/lightcap/spectral-packet-engine/logs/mcp.log
SPE_MCP_MAX_CONCURRENT=2

SPE_LOAD_MONITOR_ENABLED=true
SPE_LOAD_WINDOW_SECONDS=300
SPE_LOAD_SAMPLE_HZ=1
